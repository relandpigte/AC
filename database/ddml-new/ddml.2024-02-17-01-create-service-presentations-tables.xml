<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.1.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <changeSet author="r.pigte" id="1">
        <createTable tableName="servicepresentations">
            <column name="Id" type="CHAR(36)">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="ReferenceId" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="ServiceType" type="TINYINT">
                <constraints nullable="true"/>
			</column>
            <column name="DocumentId" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="DisplayOrder" type="SMALLINT">
                <constraints nullable="false"/>
            </column>
            <column name="CreationTime" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="CreatorUserId" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>


    <changeSet author="r.pigte" id="2">
        <createIndex indexName="FK_ServicePresentations_Document_DocumentId_idx" tableName="servicepresentations">
            <column name="DocumentId"/>
        </createIndex>
    </changeSet>
    <changeSet author="r.pigte" id="3">
        <createIndex indexName="FK_ServicePresentations_Users_CreatorUserId_idx" tableName="servicepresentations">
            <column name="CreatorUserId"/>
        </createIndex>
    </changeSet>


    <changeSet author="r.pigte" id="4">
        <addForeignKeyConstraint baseColumnNames="DocumentId" baseTableName="servicepresentations" constraintName="FK_ServicePresentations_Document_DocumentId" deferrable="false" initiallyDeferred="false" onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="Id" referencedTableName="documents" validate="true"/>
    </changeSet>
      <changeSet author="r.pigte" id="5">
        <addForeignKeyConstraint baseColumnNames="CreatorUserId" baseTableName="servicepresentations" constraintName="FK_ServicePresentations_Users_CreatorUserId" deferrable="false" initiallyDeferred="false" onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="Id" referencedTableName="abpusers" validate="true"/>
    </changeSet>
</databaseChangeLog>
