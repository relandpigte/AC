<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.1.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <changeSet author="jcezar" id="1">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="channelmembers"/>
        </preConditions> 
        <dropTable tableName="channelmembers" />
    </changeSet>
    
    <changeSet author="reland.pigte" id="1101">
        <createTable tableName="channelmembers">
            <column name="Id" type="CHAR(36)">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="UserId" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="ChannelId" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="IsTyping" defaultValueBoolean="false" type="BIT(1)">
                <constraints nullable="false"/>
            </column>
            
            <column name="CreatorUserId" type="BIGINT">
                <constraints nullable="false"/>
			</column>
            <column name="IsDeleted" type="BIT">
                <constraints nullable="false"/>
			</column>
            <column name="DeleterUserId" type="BIGINT">
                <constraints nullable="true"/>
			</column>
            <column name="DeletionTime" type="DATETIME">
                <constraints nullable="true"/>
			</column>
            <column name="LastModificationTime" type="DATETIME">
                <constraints nullable="true"/>
			</column>
            <column name="LastModifierUserId" type="BIGINT">
                <constraints nullable="true"/>
			</column>
            <column name="CreationTime" type="DATETIME">
                <constraints nullable="false"/>
			</column>
        </createTable>
    </changeSet>

    <changeSet author="reland.pigte" id="1102">
        <createIndex indexName="FK_ChannelMembers_UserId_idx" tableName="channelmembers">
            <column name="UserId"/>
        </createIndex>
    </changeSet>

    <changeSet author="reland.pigte" id="1104">
        <createIndex indexName="FK_ChannelMembers_ChannelId_idx" tableName="channelmembers">
            <column name="ChannelId"/>
        </createIndex>
    </changeSet>

    <changeSet author="reland.pigte" id="1103">
        <addForeignKeyConstraint baseColumnNames="UserId" baseTableName="channelmembers" constraintName="FK_ChannelMembers_UserId" deferrable="false" initiallyDeferred="false" onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="Id" referencedTableName="abpusers" validate="true"/>
    </changeSet>

    <changeSet author="reland.pigte" id="1105">
        <addForeignKeyConstraint baseColumnNames="ChannelId" baseTableName="channelmembers" constraintName="FK_ChannelMembers_ChannelId" deferrable="false" initiallyDeferred="false" onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="Id" referencedTableName="channels" validate="true"/>
    </changeSet>

</databaseChangeLog>
