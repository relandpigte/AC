<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.1.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <changeSet author="jcezar" id="1">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="AbpAuditLogs" columnName="ExceptionMessage" />
            </not>
        </preConditions>
        <addColumn tableName="AbpAuditLogs">
            <column name="ExceptionMessage" type="VARCHAR(2000)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet author="jcezar" id="2">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="AbpEntityPropertyChanges" columnName="OriginalValueHash" />
            </not>
        </preConditions>
        <addColumn tableName="AbpEntityPropertyChanges">
            <column name="OriginalValueHash" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet author="jcezar" id="3">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="AbpEntityPropertyChanges" columnName="NewValueHash" />
            </not>
        </preConditions>
        <addColumn tableName="AbpEntityPropertyChanges">
            <column name="NewValueHash" type="VARCHAR(512)">
                <constraints nullable="true"/>
            </column>
        </addColumn>
    </changeSet>
    
</databaseChangeLog>