<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.1.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <changeSet author="rpigte" id="1">
        <createTable tableName="channelmessagevisibility">
            <column name="Id" type="CHAR(36)">
                <constraints nullable="false" primaryKey="true"/>
            </column>
            <column name="ChannelMessageId" type="CHAR(36)">
                <constraints nullable="false"/>
            </column>
            <column name="CreatorUserId" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="CreationTime" type="datetime">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet author="rpigte" id="2">
        <createIndex indexName="FK_ChannelMessageVisibility_ChannelMessageId_idx" tableName="channelmessagevisibility">
            <column name="ChannelMessageId"/>
        </createIndex>
        <addForeignKeyConstraint baseColumnNames="ChannelMessageId" baseTableName="channelmessagevisibility" constraintName="FK_ChannelMessageVisibility_ChannelMessageId" deferrable="false" initiallyDeferred="false" onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="Id" referencedTableName="channelmessages" validate="true"/>
    </changeSet>

    <changeSet author="rpigte" id="3">
        <createIndex indexName="FK_ChannelMessageVisibility_CreatorUserId_idx" tableName="channelmessagevisibility">
            <column name="CreatorUserId"/>
        </createIndex>
        <addForeignKeyConstraint baseColumnNames="CreatorUserId" baseTableName="channelmessagevisibility" constraintName="FK_ChannelMessageVisibility_CreatorUserId" deferrable="false" initiallyDeferred="false" onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="Id" referencedTableName="abpusers" validate="true"/>
    </changeSet>
</databaseChangeLog>