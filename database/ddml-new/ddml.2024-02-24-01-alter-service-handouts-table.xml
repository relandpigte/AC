<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.1.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <changeSet author="j.cezar" id="1">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="servicehandouts" columnName="UserId" />
            </not>
        </preConditions>
        <addColumn tableName="servicehandouts">
            <column name="UserId" type="BIGINT">
                <constraints nullable="true"/>
			</column>
        </addColumn>
    </changeSet>

    <changeSet author="j.cezar" id="2">
        <createIndex indexName="FK_ServiceHandouts_Users_UserId_idx" tableName="servicehandouts">
            <column name="UserId"/>
        </createIndex>
    </changeSet>

    <changeSet author="j.cezar" id="3">
        <addForeignKeyConstraint baseColumnNames="UserId" baseTableName="servicehandouts" constraintName="FK_ServiceHandouts_Users_UserId" deferrable="false" initiallyDeferred="false" onDelete="RESTRICT" onUpdate="RESTRICT" referencedColumnNames="Id" referencedTableName="abpusers" validate="true"/>
    </changeSet>
</databaseChangeLog>
