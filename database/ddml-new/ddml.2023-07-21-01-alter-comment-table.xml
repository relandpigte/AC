<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.1.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <changeSet author="rpigte" id="1">
        <preConditions onFail="MARK_RAN">
           <not>
                <columnExists tableName="comments" columnName="IsDeleted" />
            </not>
        </preConditions>
        <addColumn tableName="comments">
            <column name="IsDeleted" type="BIT">
                <constraints nullable="false"/>
			</column>
        </addColumn>
    </changeSet>
    <changeSet author="rpigte" id="2">
        <preConditions onFail="MARK_RAN">
          <not>
                <columnExists tableName="comments" columnName="DeleterUserId" />
            </not>
        </preConditions>
       
        <addColumn tableName="comments">
            <column name="DeleterUserId" type="BIGINT">
                <constraints nullable="true"/>
			</column>
        </addColumn>
    </changeSet>
    <changeSet author="rpigte" id="3">
        <preConditions onFail="MARK_RAN">
          <not>
                <columnExists tableName="comments" columnName="DeletionTime" />
            </not>
        </preConditions>
       
        <addColumn tableName="comments">
            <column name="DeletionTime" type="DATETIME">
                <constraints nullable="true"/>
			</column>
        </addColumn>
    </changeSet>
    <changeSet author="rpigte" id="4">
        <preConditions onFail="MARK_RAN">
           <not>
                <columnExists tableName="comments" columnName="LastModificationTime" />
            </not>
        </preConditions>
         <addColumn tableName="comments">
            <column name="LastModificationTime" type="DATETIME">
                <constraints nullable="true"/>
			</column>
        </addColumn>
    </changeSet>
    <changeSet author="rpigte" id="5">
        <preConditions onFail="MARK_RAN">
          <not>
                <columnExists tableName="comments" columnName="LastModifierUserId" />
            </not>
        </preConditions>
        <addColumn tableName="comments">
            <column name="LastModifierUserId" type="BIGINT">
                <constraints nullable="true"/>
			</column>
        </addColumn>
    </changeSet>
    <changeSet author="rpigte" id="6">
        <preConditions onFail="MARK_RAN">
          <not>
                <columnExists tableName="comments" columnName="CreationTime" />
            </not>
        </preConditions>
        <addColumn tableName="comments">
            <column name="CreationTime" type="DATETIME">
                <constraints nullable="false"/>
			</column>
        </addColumn>
    </changeSet>
</databaseChangeLog>