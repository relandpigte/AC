<?xml version="1.1" encoding="UTF-8" standalone="no"?>
<databaseChangeLog xmlns="http://www.liquibase.org/xml/ns/dbchangelog" xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext" xmlns:pro="http://www.liquibase.org/xml/ns/pro" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd http://www.liquibase.org/xml/ns/pro http://www.liquibase.org/xml/ns/pro/liquibase-pro-4.1.xsd http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.1.xsd">
    <changeSet author="Ferlyn Capulong" id="1">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="academicallyposts" columnName="LastModificationTime" />
            </not>
            <not>
                <columnExists tableName="academicallyposts" columnName="LastModifierUserId" />
            </not>
            <not>
                <columnExists tableName="academicallyposts" columnName="IsDeleted" />
            </not>
            <not>
                <columnExists tableName="academicallyposts" columnName="DeletionTime" />
            </not>
            <not>
                <columnExists tableName="academicallyposts" columnName="DeleterUserId" />
            </not>
        </preConditions>
    </changeSet>
    <changeSet author="Ferlyn Capulong" id="2">
        <addColumn tableName="academicallyposts">
            <column name="LastModificationTime" type="DATETIME">
                <constraints nullable="true"/>
			</column>
        </addColumn>
        <addColumn tableName="academicallyposts">
            <column name="LastModifierUserId" type="BIGINT">
                <constraints nullable="true"/>
			</column>
        </addColumn>
        <addColumn tableName="academicallyposts">
            <column name="IsDeleted" type="BIT">
                <constraints nullable="false"/>
			</column>
        </addColumn>
        <addColumn tableName="academicallyposts">
            <column name="DeletionTime" type="DATETIME">
                <constraints nullable="true"/>
			</column>
        </addColumn>
        <addColumn tableName="academicallyposts">
            <column name="DeleterUserId" type="BIGINT">
                <constraints nullable="true"/>
			</column>
        </addColumn>
    </changeSet>
</databaseChangeLog>