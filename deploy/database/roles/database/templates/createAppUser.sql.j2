CREATE {{db_name}};
GO

CREATE LOGIN {{db_app_user}} WITH PASSWORD = '{{db_app_password}}', CHECK_POLICY = OFF
GO

Use {{db_name}};
GO

IF NOT EXISTS (SELECT * FROM sys.database_principals WHERE name = N'{{db_app_user}}')
BEGIN
    CREATE USER [{{db_app_user}}] FOR LOGIN [{{db_app_user}}]
    EXEC sp_addrolemember N'db_datareader', N'{{db_app_user}}'
    EXEC sp_addrolemember N'db_datawriter', N'{{db_app_user}}'
END;
GO

