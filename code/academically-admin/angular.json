{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "academically": {
      "root": "",
      "sourceRoot": "src",
      "projectType": "application",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "aot": true,
            "outputPath": "dist",
            "index": "src/index.html",
            "main": "src/main.ts",
            "tsConfig": "src/tsconfig.json",
            "polyfills": "src/polyfills.ts",
            "assets": [
              "src/assets",
              "src/favicon.ico",
              {
                "glob": "abp.signalr.js",
                "input": "node_modules/abp-web-resources/Abp/Framework/scripts/libs",
                "output": "/assets/abp"
              },
              {
                "glob": "abp.signalr-client.js",
                "input": "node_modules/abp-web-resources/Abp/Framework/scripts/libs",
                "output": "/assets/abp"
              }
            ],
            "styles": [
              "node_modules/famfamfam-flags/dist/sprite/famfamfam-flags.css",
              "node_modules/sweetalert2/dist/sweetalert2.css",
              "src/assets/freeze-ui/freeze-ui.css",
              "node_modules/@fortawesome/fontawesome-free/css/all.min.css",
              "node_modules/ngx-bootstrap/datepicker/bs-datepicker.css",
              "src/assets/themes/dashkit/fonts/feather/feather.css",
              "src/assets/themes/dashkit/libs/flatpickr/dist/flatpickr.min.css",
              "src/assets/themes/dashkit/libs/quill/dist/quill.core.css",
              "src/assets/themes/dashkit/libs/highlightjs/styles/vs2015.css",
              "src/assets/themes/dashkit/css/theme.min.css",
              "src/shared/core.less"
            ],
            "scripts": [
              "node_modules/moment/min/moment.min.js",
              "node_modules/@aspnet/signalr/dist/browser/signalr.min.js",
              "node_modules/sweetalert2/dist/sweetalert2.js",
              "src/assets/freeze-ui/freeze-ui.js",
              "node_modules/push.js/bin/push.min.js",
              "src/assets/themes/dashkit/libs/jquery/dist/jquery.min.js",
              "src/assets/themes/dashkit/libs/@shopify/draggable/lib/es5/draggable.bundle.legacy.js",
              "src/assets/themes/dashkit/libs/autosize/dist/autosize.min.js",
              "src/assets/themes/dashkit/libs/chart.js/dist/Chart.min.js",
              "src/assets/themes/dashkit/libs/dropzone/dist/min/dropzone.min.js",
              "src/assets/themes/dashkit/libs/flatpickr/dist/flatpickr.min.js",
              "src/assets/themes/dashkit/libs/highlightjs/highlight.pack.min.js",
              "src/assets/themes/dashkit/libs/jquery-mask-plugin/dist/jquery.mask.min.js",
              "src/assets/themes/dashkit/libs/list.js/dist/list.min.js",
              "src/assets/themes/dashkit/libs/quill/dist/quill.min.js",
              "src/assets/themes/dashkit/libs/select2/dist/js/select2.full.min.js",
              "src/assets/themes/dashkit/libs/chart.js/Chart.extension.js",
              "node_modules/abp-web-resources/Abp/Framework/scripts/abp.js",
              "src/assets/abp-web-resources/abp.sweet-alert.js",
              "src/assets/abp-web-resources/abp.freeze-ui.js",
              "node_modules/abp-web-resources/Abp/Framework/scripts/libs/abp.moment.js"
            ]
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ]
            },
            "uat": {
              "optimization": true,
              "outputHashing": "all",
              "sourceMap": false,
              "extractCss": true,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "vendorChunk": false,
              "buildOptimizer": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.uat.ts"
                }
              ]
            },
            "ci": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.ci.ts"
                }
              ]
            },
            "hmr": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.hmr.ts"
                }
              ]
            }
          }
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "browserTarget": "academically:build",
            "port": 6360
          },
          "configurations": {
            "production": {
              "browserTarget": "academically:build:production"
            },
            "hmr": {
              "browserTarget": "academically:build:hmr"
            }
          }
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "browserTarget": "academically:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "src/test.ts",
            "karmaConfig": "./karma.conf.js",
            "polyfills": "src/polyfills.ts",
            "assets": [
              "src/assets",
              "src/favicon.ico",
              {
                "glob": "abp.signalr.js",
                "input": "node_modules/abp-web-resources/Abp/Framework/scripts/libs",
                "output": "/assets/abp"
              },
              {
                "glob": "abp.signalr-client.js",
                "input": "node_modules/abp-web-resources/Abp/Framework/scripts/libs",
                "output": "/assets/abp"
              }
            ],
            "styles": [
              "node_modules/famfamfam-flags/dist/sprite/famfamfam-flags.css",
              "node_modules/sweetalert2/dist/sweetalert2.css",
              "src/assets/freeze-ui/freeze-ui.css",
              "node_modules/@fortawesome/fontawesome-free/css/all.min.css",
              "node_modules/admin-lte-css-only/css/adminlte.min.css",
              "src/shared/core.less"
            ],
            "scripts": [
              "node_modules/moment/min/moment.min.js",
              "node_modules/@aspnet/signalr/dist/browser/signalr.min.js",
              "node_modules/sweetalert2/dist/sweetalert2.js",
              "src/assets/freeze-ui/freeze-ui.js",
              "node_modules/push.js/bin/push.min.js",
              "node_modules/abp-web-resources/Abp/Framework/scripts/abp.js",
              "src/assets/abp-web-resources/abp.sweet-alert.js",
              "src/assets/abp-web-resources/abp.freeze-ui.js",
              "node_modules/abp-web-resources/Abp/Framework/scripts/libs/abp.moment.js"
            ]
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "src/tsconfig.json"
            ],
            "exclude": []
          }
        }
      }
    },
    "academically-e2e": {
      "root": "",
      "sourceRoot": "",
      "projectType": "application",
      "architect": {
        "e2e": {
          "builder": "@angular-devkit/build-angular:protractor",
          "options": {
            "protractorConfig": "./protractor.conf.js",
            "devServerTarget": "academically:serve"
          }
        },
        "lint": {
          "builder": "@angular-devkit/build-angular:tslint",
          "options": {
            "tsConfig": [
              "e2e/tsconfig.json"
            ],
            "exclude": []
          }
        }
      }
    }
  },
  "defaultProject": "academically",
  "schematics": {
    "@schematics/angular:component": {
      "prefix": "app",
      "style": "less",
      "skipTests": true
    },
    "@schematics/angular:directive": {
      "prefix": "app",
      "skipTests": true
    },
    "@schematics/angular:class": {
      "skipTests": true
    },
    "@schematics/angular:pipe": {
      "skipTests": true
    },
    "@schematics/angular:service": {
      "skipTests": true
    }
  }
}
